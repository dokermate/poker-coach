FROM python:3.12-slim

WORKDIR /app

COPY pyproject.toml .
COPY app/ ./app/
COPY gto_advisor/ ./gto_advisor/
COPY alembic/ ./alembic/
COPY alembic.ini .

RUN pip install --no-cache-dir fastapi uvicorn[standard] sqlalchemy alembic python-jose[cryptography] passlib[bcrypt] python-multipart "pydantic[email]" pydantic-settings treys aiosqlite greenlet email-validator

EXPOSE 8000

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]