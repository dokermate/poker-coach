# Copy this file to .env and fill in your values
# cp .env.example .env

# Database (SQLite for dev, PostgreSQL for production)
DATABASE_URL=sqlite+aiosqlite:///./poker_coach.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost/poker_coach

# Security — CHANGE THIS before deploying!
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-32-byte-hex-string

# Token expiry (default: 1 week)
ACCESS_TOKEN_EXPIRE_MINUTES=10080
